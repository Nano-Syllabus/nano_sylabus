NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=900
GEMINI_THINKING_BUDGET=256
GEMINI_REWRITE_MAX_OUTPUT_TOKENS=320
GEMINI_REWRITE_THINKING_BUDGET=64
GEMINI_FOLLOWUP_MAX_OUTPUT_TOKENS=220
GEMINI_FOLLOWUP_THINKING_BUDGET=64
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# Optional OpenRouter runtime (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_QUICK_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_DEEP_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MAX_OUTPUT_TOKENS=900
OPENROUTER_REWRITE_MAX_OUTPUT_TOKENS=320
OPENROUTER_FOLLOWUP_MAX_OUTPUT_TOKENS=220
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=

# Chat runtime guards
CHAT_GENERATE_FOLLOWUPS=0
CHAT_RAG_TIMEOUT_MS=3500
CHAT_MODEL_TIMEOUT_MS=18000
CHAT_REWRITE_TIMEOUT_MS=7000
CHAT_MAX_RETRIES=0
CHAT_ENABLE_QUALITY_RESCUE=0
