<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error 404</title>

    <style>
      .error-404 .custom-container {
        display: flex;
        justify-content: center;
        align-items: center;
      }
      
      .error-404 svg {
        max-width: 600px;
        height: 80vh;
      }
      
      .cls-5 {
        animation: bgColorGlow 1s alternate infinite;
        fill: var(--theme-color);
      }
      
      @keyframes bgColorGlow {
        0% {
          opacity: 0.3;
        }
      
        100% {
          opacity: 1;
        }
      }
    </style>
  </head>

